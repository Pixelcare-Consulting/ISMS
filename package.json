{
  "name": "isms",
  "version": "0.9.6",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "postinstall": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:only": "dotenv -e .env.local -- prisma migrate dev --skip-seed",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:seed:full": "dotenv -e .env.local -- node scripts/seed-profile.mjs full",
    "db:seed:core": "dotenv -e .env.local -- node scripts/seed-profile.mjs core",
    "db:seed:brs": "dotenv -e .env.local -- node scripts/seed-profile.mjs brs",
    "db:seed:status": "dotenv -e .env.local -- node scripts/seed-profile.mjs status",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "docs:modules-matrix": "node scripts/generate-modules-workflow-excel.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.554.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pino": "^10.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.66.1",
    "resend": "^6.12.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pino-pretty": "^13.1.2",
    "@types/pg": "^8.15.4",
    "prisma": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
